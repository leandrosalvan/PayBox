generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  emailVerified      DateTime?
  name               String?
  image              String?
  password           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  accounts           Account[]
  sessions           Session[]
  walletMemberships  WalletMember[]
  invitesSent        WalletInvite[]      @relation("InvitedBy")
  expensesCreated    Expense[]           @relation("CreatedBy")
  expensesPaid       Expense[]           @relation("PaidBy")
  seriesCreated      ExpenseSeries[]     @relation("SeriesCreatedBy")
  seriesDefaultPayer  ExpenseSeries[]     @relation("SeriesDefaultPayer")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Wallet {
  id          String         @id @default(cuid())
  inviteToken String         @unique @default(cuid())
  name        String
  locale      String         @default("pt-BR")
  currency    String         @default("BRL")
  salaryMode  String         @default("joint")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  members     WalletMember[]
  invites     WalletInvite[]
  categories  Category[]
  series      ExpenseSeries[]
  expenses    Expense[]
}

model WalletMember {
  id       String  @id @default(cuid())
  walletId String
  userId   String
  salary   Int @default(0)
  role     String  @default("member")
  joinedAt DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([walletId, userId])
}

model WalletInvite {
  id          String    @id @default(cuid())
  walletId    String
  email       String
  token       String    @unique
  status      String    @default("pending")
  invitedById String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  wallet    Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  invitedBy User?  @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([walletId, email])
}

model Category {
  id        String          @id @default(cuid())
  walletId  String
  name      String
  color     String          @default("#10b981")
  icon      String          @default("tag")
  createdAt DateTime        @default(now())
  expenses  Expense[]
  series    ExpenseSeries[]

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, name])
}

model ExpenseSeries {
  id                  String     @id @default(cuid())
  walletId            String
  description         String
  amount              Int
  dueDay              Int
  categoryId          String?
  startDate           DateTime
  endDate             DateTime?
  type                String     @default("single")
  totalInstallments   Int?
  createdById         String
  paidByDefaultId     String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  wallet          Wallet     @relation(fields: [walletId], references: [id], onDelete: Cascade)
  category        Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy       User       @relation("SeriesCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  paidByDefault   User?      @relation("SeriesDefaultPayer", fields: [paidByDefaultId], references: [id], onDelete: SetNull)
  expenses        Expense[]
}

model Expense {
  id                String           @id @default(cuid())
  seriesId          String?
  walletId          String
  description       String
  amount            Int
  dueDate           DateTime
  paidAt            DateTime?
  paidById          String?
  status            String           @default("pending")
  installmentNumber Int?
  createdById       String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  wallet     Wallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  series     ExpenseSeries? @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  paidBy     User?          @relation("PaidBy", fields: [paidById], references: [id], onDelete: SetNull)
  createdBy  User           @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  category   Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId String?
}
